{
  "initializationAction": "(q.npc.is_in_battle_with(q.player) || !q.npc.is_doing_activity('minecraft:idle', 'cobblemon:battling')) ? q.dialogue.close()",
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
        {
      "id": "npc-chat",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Hello, ' + q.player.username + '! I\\'m ' + q.npc.name + '! Are you ready to battle?'"
        }
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": "Battle",
            "value": "battle",
            "action": [
              "q.dialogue.close();",
              "q.npc.start_battle(q.player, 'double');"
            ],
            "isSelectable": "c.npc.can_battle;"
          },
          {
            "text": "Cancel",
            "value": "cancel",
            "action": [
              "q.dialogue.close()"
            ]
          }
        ]
      }
    }
  ]
}